{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/post-build-verify.sh\"",
            "timeout": 15,
            "statusMessage": "Checking for BC build (post-build verifier reminder)..."
          }
        ]
      }
    ]
  }
}
