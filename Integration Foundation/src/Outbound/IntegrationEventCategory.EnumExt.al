enumextension 73298418 "Integration Event Category" extends "EventCategory"
{
    // Category for the extension's external business events. The [ExternalBusinessEvent]
    // Category argument must be a value of the platform "EventCategory" enum, so this
    // adds our value to that enum rather than defining a standalone one.
    value(73298418; IntegrationFoundation) { Caption = 'Integration Foundation'; }
}
